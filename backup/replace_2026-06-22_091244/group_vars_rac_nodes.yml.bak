  - name: OCR01
    path: /dev/disk/by-id/ata-VBOX_HARDDISK_VB257fe329-bac46c41
    group: OCR
  - name: DATA01
    path: /dev/disk/by-id/ata-VBOX_HARDDISK_VB6320f92e-9896e99f
    group: DATA
  - name: FRA01
    path: /dev/disk/by-id/ata-VBOX_HARDDISK_VB956885ed-81b8d617
