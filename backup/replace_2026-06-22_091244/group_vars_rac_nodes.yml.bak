db_name: TESTCDB
pdb_name: TESTPDB

asm_diskstring: /dev/disk/by-id/*
ocr_disk: /dev/disk/by-id/ata-VBOX_HARDDISK_VB257fe329-bac46c41
data_disk: /dev/disk/by-id/ata-VBOX_HARDDISK_VB6320f92e-9896e99f
fra_disk: /dev/disk/by-id/ata-VBOX_HARDDISK_VB956885ed-81b8d617

